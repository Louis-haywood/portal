# Port the Node.js server listens on (Caddy proxies this)
PORT=3000

# A long random string — copy this to your watcher .env too
API_KEY=change_me_to_a_long_random_string

# Where uploaded files are stored on the VPS
UPLOAD_DIR=C:\cdn\uploads

# Public base URL of your CDN
CDN_BASE_URL=https://cdn.haywood.ltd
