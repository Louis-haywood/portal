# Local folder to watch — drop images/videos here
# Default if unset: ~/CDN
WATCH_DIR=C:\Users\YourName\CDN

# Your CDN server URL
CDN_URL=https://cdn.haywood.ltd

# Must match API_KEY in cdn-server/.env
API_KEY=change_me_to_a_long_random_string

# Set to true if you want local deletes to also remove files from CDN
DELETE_ON_REMOVE=false
